//@version=5
strategy("C - limit 14 SHORT (EVEN) bingX COMP [Ladyinet edition]",
     overlay=true,
     pyramiding=300,
     initial_capital=100,
     default_qty_type=strategy.fixed,
     commission_type=strategy.commission.percent,
     commission_value=0.0,
     process_orders_on_close=true,
     calc_on_order_fills=true)

// Close-only execution model:
// - усі внутрішні розрахунки робляться по close поточного бара
// - nextLevelPrice / TP-рівні використовуються як умови-тригери
//
// HYBRID / LIVE ARCHITECTURE:
// - режим backtest      -> використовує strategy.entry / strategy.close* для тестів у TV
// - режим hybrid_alerts -> TV не намагається "керувати біржею", а шле JSON alert у webhook
// - зовнішній бот має читати webhook, брати реальний стан з API BingX і вже там приймати
//   фінальне рішення щодо виконання / закриття позиції
// - manual state в Pine залишений, щоб не ламати логіку циклів, лейбли і plotting
//
// Інші особливості:
// - % sizing від фіксованого equityForSizingUSDT
// - у strategy.entry(... qty=...) передається coin qty
// - close-confirmation для FULL TP / DCA зроблені окремими опціями
// - для SUB-COVER додано режим підтвердження close:
//      off          -> без додаткової close-умови
//      breakeven    -> close <= entryLast (м'якша умова)
//      subcover_tp  -> close <= lastLotTP (жорстка умова)
// - окремою опцією можна вмикати або вимикати блокування DCA на сам факт TP-touch

// =====================
// Inputs
// =====================
firstSellQtyCoin    = input.float(0.09, "First Short (coin qty)", minval=0.000001, step=0.001)
minOrderQtyCoin     = input.float(0.09, "Min order qty (coin)", minval=0.0, step=0.001)
useEquityPctBase    = input.bool(false, "Base order as % of fixed equity")
baseOrderPctEq      = input.float(1.0,  "Base order % of fixed equity", minval=0.01, step=0.01)
equityForSizingUSDT = input.float(100.0, "Equity for % sizing (USDT)", minval=0.01, step=0.01)

tpPercent         = input.float(1.1,  "TP % (Whole warehouse)", step=0.1)
callbackPercent   = input.float(0.2,  "Callback % (Trailing)", step=0.05)
marginCallLimit   = input.int(244,    "Margin Call Limit (max shorts)", minval=1)
linearRisePercent = input.float(0.5,  "Margin Call Rise % (after lvl 5)", step=0.1)

autoMerge        = input.bool(true, "Auto Merge")
subSellTPPercent = input.float(1.3, "Sub-cover TP % (last lot)", step=0.1)

// Гнучкі опції логіки
requireCloseBelowFullTP   = input.bool(true,  "Require close <= Full TP for full cover")
subCoverCloseConfirmMode  = input.string("breakeven", "Sub-cover close confirmation", options=["off", "breakeven", "subcover_tp"])
requireCloseAboveDcaLevel = input.bool(true,  "Require close >= Next DCA level")
blockDcaOnTpTouch         = input.bool(false, "Block DCA on Full TP touch even without close confirm")

// Nonlinear initial rises (lvl2..lvl6)
rise1 = input.float(0.3, "Nonlinear rise lvl2 %", step=0.1)
rise2 = input.float(0.4, "Nonlinear rise lvl3 %", step=0.1)
rise3 = input.float(0.6, "Nonlinear rise lvl4 %", step=0.1)
rise4 = input.float(0.8, "Nonlinear rise lvl5 %", step=0.1)
rise5 = input.float(0.8, "Nonlinear rise lvl6 %", step=0.1)

// Multipliers (lvl2..lvl5), after lvl5 -> 1x
mult2 = input.float(1.5, "Multiplier lvl2", step=0.1)
mult3 = input.float(1.0, "Multiplier lvl3", step=0.1)
mult4 = input.float(2.0, "Multiplier lvl4", step=0.1)
mult5 = input.float(3.5, "Multiplier lvl5", step=0.1)

maxFillsPerBar    = input.int(6,  "Max DCA fills per bar", minval=1, maxval=20)
maxSubSellsPerBar = input.int(10, "Max SUB-covers per bar", minval=1, maxval=50)
useHighLowTouch   = input.bool(true, "Check trigger touch by Low/High (else Open/Close body)")

executionMode    = input.string("backtest", "Execution mode", options=["backtest", "hybrid_alerts"])
sendEntryAlerts  = input.bool(true, "Hybrid: send entry alerts too")
alertSourceTag   = input.string("tv_bingx_hybrid", "Alert source tag")
webhookToken     = input.string("", "Webhook token / secret (optional)")
debugSendTestAlert = input.bool(false, "Hybrid debug: send one TEST_ALERT on next confirmed bar")

// =====================
// Shared parity anchor
// =====================
anchorTz       = "UTC"
anchorTs       = timestamp(anchorTz, year, 1, 1, 0, 0)
barMs          = int(timeframe.in_seconds(timeframe.period) * 1000)
barsFromAnchor = int(math.floor((time - anchorTs) / barMs))
afterAnchor    = time >= anchorTs
allowThisBar   = afterAnchor and (barsFromAnchor % 2 == 0)

// =====================
// Live sync start
// =====================
useLiveSyncStart = input.bool(true, "Use live sync start")
liveStartTime    = input.time(0, "Live sync start time (UTC)")

liveNow      = not useLiveSyncStart or time >= liveStartTime
livePrev     = bar_index > 0 ? (not useLiveSyncStart or time[1] >= liveStartTime) : false
liveStartBar = liveNow and not livePrev

// =====================
// Order-fill throttle (rolling 3-minute window, order fills only)
// =====================
maxOrdersPer3Min = input.int(14, "Max fills in last 3 min", minval=1, maxval=100)

barSeconds        = timeframe.in_seconds(timeframe.period)
barsIn3MinWindow  = math.max(1, int(math.ceil(180.0 / barSeconds)))
historyBarsLimit  = math.max(barsIn3MinWindow - 1, 0)

var int ordersThisBar         = 0
var int ordersBarIndex        = na
var int[] recentBarFills      = array.new_int()
var int recentHistoryFills    = 0
var int maxOrdersPerBarBT     = 0
var int maxOrdersBarTime      = na
var int maxOrdersPerWindowBT  = 0
var int maxOrdersWindowTime   = na
var int fullTPWarehouseCloses = 0
var label maxOrdersLabel      = na

if na(ordersBarIndex)
    ordersBarIndex := bar_index
    ordersThisBar  := 0
else if bar_index != ordersBarIndex
    if historyBarsLimit > 0
        array.push(recentBarFills, ordersThisBar)
        recentHistoryFills += ordersThisBar
        if array.size(recentBarFills) > historyBarsLimit
            removed = array.shift(recentBarFills)
            recentHistoryFills -= removed
    else
        recentHistoryFills := 0

    ordersThisBar  := 0
    ordersBarIndex := bar_index

recentOrdersIn3Min = recentHistoryFills + ordersThisBar

if recentOrdersIn3Min > maxOrdersPerWindowBT
    maxOrdersPerWindowBT := recentOrdersIn3Min
    maxOrdersWindowTime  := time

triggerHigh = useHighLowTouch ? high : math.max(open, close)
triggerLow  = useHighLowTouch ? low  : math.min(open, close)

f_canPlaceOrder() =>
    liveNow and allowThisBar and recentOrdersIn3Min < maxOrdersPer3Min

isHybridMode = executionMode == "hybrid_alerts"

// =====================
// JSON / webhook helpers
// =====================
f_jsonStr(_v) =>
    "\"" + _v + "\""

f_jsonNum(_v) =>
    na(_v) ? "null" : str.tostring(_v, "#.########")

f_jsonInt(_v) =>
    na(_v) ? "null" : str.tostring(_v)

f_jsonBool(_v) =>
    _v ? "true" : "false"

f_kvStr(_k, _v) =>
    f_jsonStr(_k) + ":" + f_jsonStr(_v)

f_kvNum(_k, _v) =>
    f_jsonStr(_k) + ":" + f_jsonNum(_v)

f_kvInt(_k, _v) =>
    f_jsonStr(_k) + ":" + f_jsonInt(_v)

f_kvBool(_k, _v) =>
    f_jsonStr(_k) + ":" + f_jsonBool(_v)

f_optionalToken() =>
    webhookToken != "" ? "," + f_kvStr("token", webhookToken) : ""

f_alertSymbol() =>
    _base = syminfo.basecurrency
    _quote = syminfo.currency
    _base != "" and _quote != "" ? _base + _quote : syminfo.ticker

f_emitAlert(_payload) =>
    alert(_payload, alert.freq_all)

f_sendTestAlert() =>
    _payload =
         "{" +
         f_kvStr("source", alertSourceTag) + "," +
         f_kvStr("mode", executionMode) + "," +
         f_kvStr("action", "TEST_ALERT") + "," +
         f_kvStr("reason", "MANUAL_HYBRID_DEBUG") + "," +
         f_kvStr("symbol", f_alertSymbol()) + "," +
         f_kvStr("orderId", "debug-" + str.tostring(time)) + "," +
         f_kvInt("barTime", time) + "," +
         f_kvInt("timestamp", timenow) +
         f_optionalToken() +
         "}"
    f_emitAlert(_payload)

f_sendEntryAlert(_action, _orderId, _lotTag, _qtyCoin, _triggerPrice, _fillPrice, _theoreticalAvg, _tpPrice, _nextLevelPrice, _numSells) =>
    _payload =
         "{" +
         f_kvStr("source", alertSourceTag) + "," +
         f_kvStr("mode", executionMode) + "," +
         f_kvStr("action", _action) + "," +
         f_kvStr("symbol", f_alertSymbol()) + "," +
         f_kvStr("side", "SHORT") + "," +
         f_kvStr("orderId", _orderId) + "," +
         f_kvStr("lotTag", _lotTag) + "," +
         f_kvNum("qtyCoin", _qtyCoin) + "," +
         f_kvNum("triggerPrice", _triggerPrice) + "," +
         f_kvNum("fillPrice", _fillPrice) + "," +
         f_kvNum("theoreticalAvg", _theoreticalAvg) + "," +
         f_kvNum("tpPrice", _tpPrice) + "," +
         f_kvNum("nextLevelPrice", _nextLevelPrice) + "," +
         f_kvInt("numSells", _numSells) + "," +
         f_kvInt("barTime", time) + "," +
         f_kvInt("timestamp", timenow) +
         f_optionalToken() +
         "}"
    f_emitAlert(_payload)

f_sendFullTpCloseAlert(string _reason, float _theoreticalAvg, float _tpPrice, float _currentClose, float _trailingMin, float _trailStop, float _positionQty, int _numSells, bool _tpTouched, bool _tpCloseConfirmed) =>
    _payload =
         "{" +
         f_kvStr("source", alertSourceTag) + "," +
         f_kvStr("mode", executionMode) + "," +
         f_kvStr("action", "FULL_TP_CLOSE") + "," +
         f_kvStr("reason", _reason) + "," +
         f_kvStr("symbol", f_alertSymbol()) + "," +
         f_kvNum("theoreticalAvg", _theoreticalAvg) + "," +
         f_kvNum("tpPercent", tpPercent) + "," +
         f_kvNum("tpPrice", _tpPrice) + "," +
         f_kvNum("currentClose", _currentClose) + "," +
         f_kvNum("callbackPercent", callbackPercent) + "," +
         f_kvNum("trailingMin", _trailingMin) + "," +
         f_kvNum("trailStop", _trailStop) + "," +
         f_kvNum("theoreticalPositionQty", _positionQty) + "," +
         f_kvInt("numSells", _numSells) + "," +
         f_kvBool("tpTouched", _tpTouched) + "," +
         f_kvBool("tpCloseConfirmed", _tpCloseConfirmed) + "," +
         f_kvInt("barTime", time) + "," +
         f_kvInt("timestamp", timenow) +
         f_optionalToken() +
         "}"
    f_emitAlert(_payload)

f_sendSubCoverAlert(_orderId, _lotTag, _qtyCoin, _entryPrice, _lotTp, _currentClose, _theoreticalAvg, _positionQty, _numSells) =>
    _payload =
         "{" +
         f_kvStr("source", alertSourceTag) + "," +
         f_kvStr("mode", executionMode) + "," +
         f_kvStr("action", "SUBCOVER_CLOSE") + "," +
         f_kvStr("symbol", f_alertSymbol()) + "," +
         f_kvStr("side", "SHORT") + "," +
         f_kvStr("orderId", _orderId) + "," +
         f_kvStr("lotTag", _lotTag) + "," +
         f_kvNum("qtyCoin", _qtyCoin) + "," +
         f_kvNum("entryPrice", _entryPrice) + "," +
         f_kvNum("lotTpPrice", _lotTp) + "," +
         f_kvNum("currentClose", _currentClose) + "," +
         f_kvNum("theoreticalAvg", _theoreticalAvg) + "," +
         f_kvNum("theoreticalPositionQty", _positionQty) + "," +
         f_kvInt("numSells", _numSells) + "," +
         f_kvStr("subCoverMode", subCoverCloseConfirmMode) + "," +
         f_kvInt("barTime", time) + "," +
         f_kvInt("timestamp", timenow) +
         f_optionalToken() +
         "}"
    f_emitAlert(_payload)

f_execEntry(_id, _qty, _comment, _action, _lotTag, _triggerPrice, _fillPrice, _theoreticalAvg, _tpPrice, _nextLevelPrice, _numSells) =>
    if isHybridMode
        if sendEntryAlerts
            f_sendEntryAlert(_action, _id, _lotTag, _qty, _triggerPrice, _fillPrice, _theoreticalAvg, _tpPrice, _nextLevelPrice, _numSells)
    else
        strategy.entry(_id, strategy.short, qty=_qty, comment=_comment)

f_execFullClose(string _comment, string _reason, float _theoreticalAvg, float _tpPrice, float _currentClose, float _trailingMin, float _trailStop, float _positionQty, int _numSells, bool _tpTouched, bool _tpCloseConfirmed) =>
    if isHybridMode
        f_sendFullTpCloseAlert(_reason, _theoreticalAvg, _tpPrice, _currentClose, _trailingMin, _trailStop, _positionQty, _numSells, _tpTouched, _tpCloseConfirmed)
    else
        strategy.close_all(comment=_comment)

f_execSubCover(_id, _comment, _lotTag, _qty, _entryPrice, _lotTp, _currentClose, _theoreticalAvg, _positionQty, _numSells) =>
    if isHybridMode
        f_sendSubCoverAlert(_id, _lotTag, _qty, _entryPrice, _lotTp, _currentClose, _theoreticalAvg, _positionQty, _numSells)
    else
        strategy.close(_id, comment=_comment)

// =====================
// Helper funcs
// =====================
f_getRiseForNextLevel(_numSells) =>
    ns = _numSells + 1
    ns == 2 ? rise1 :
     ns == 3 ? rise2 :
     ns == 4 ? rise3 :
     ns == 5 ? rise4 :
     ns == 6 ? rise5 :
     linearRisePercent

f_getMultForNextLevel(_numSells) =>
    ns = _numSells + 1
    ns == 2 ? mult2 :
     ns == 3 ? mult3 :
     ns == 4 ? mult4 :
     ns == 5 ? mult5 :
     1.0

f_nextLevel(_lastFillPrice, _numSells) =>
    r = f_getRiseForNextLevel(_numSells)
    _lastFillPrice * (1.0 + r / 100.0)

f_recalcAvg(_proceeds, _sizeAbs) =>
    _sizeAbs > 0 ? _proceeds / _sizeAbs : na

f_calcBaseOrderQtyCoin() =>
    rawQtyCoin = useEquityPctBase ? ((equityForSizingUSDT * baseOrderPctEq / 100.0) / close) : firstSellQtyCoin
    math.max(rawQtyCoin, minOrderQtyCoin)

f_lotTag(_n) =>
    _n == 1 ? "ds1" :
     _n <= 6 ? "dsN" + str.tostring(_n) :
     "ds" + str.tostring(_n)

// =====================
// State
// =====================
var float posSizeAbs      = 0.0
var float posProceedsUSDT = 0.0
var float avgPrice        = na
var int   numSells        = 0
var float lastFillPrice   = na
var float nextLevelPrice  = na

// LIFO lots
var int      lotCounter = 0
var string[] lotIds     = array.new_string()
var float[]  lotQty     = array.new_float()
var float[]  lotPrice   = array.new_float()
var string[] lotTags    = array.new_string()
var float[]  lotUsdt    = array.new_float()

// Cycle-level counters
var int cycleScCounter = 0

// trailing for full TP
var bool  trailingActive   = false
var float trailingMin      = na
var float cycleBaseQtyCoin = na

// cycle flags
var bool resetCycle       = false
var bool restartedThisBar = false
var bool debugTestAlertSent = false
restartedThisBar := false

// =====================
// Bar event aggregation
// =====================
var string barEvents    = ""
var bool   barHasAction = false
var string barDcaBlock  = ""
var string barScBlock   = ""

if barstate.isnew
    barEvents    := ""
    barHasAction := false
    barDcaBlock  := ""
    barScBlock   := ""

f_addEvent(_currEvents, _text) =>
    _nextEvents = _currEvents == "" ? _text : _currEvents + "\n" + _text
    [_nextEvents, true]

if not debugSendTestAlert
    debugTestAlertSent := false

if barstate.isconfirmed and isHybridMode and liveNow and debugSendTestAlert and not debugTestAlertSent
    f_sendTestAlert()
    debugTestAlertSent := true
    [barEvents, barHasAction] = f_addEvent(barEvents, "TEST ALERT @" + str.tostring(close, "#.####"))

// =====================
// HARD RESET AT LIVE START
// =====================
if liveStartBar
    posSizeAbs       := 0.0
    posProceedsUSDT  := 0.0
    avgPrice         := na
    numSells         := 0
    lastFillPrice    := na
    nextLevelPrice   := na
    trailingActive   := false
    trailingMin      := na
    cycleBaseQtyCoin := na
    cycleScCounter   := 0
    array.clear(lotIds)
    array.clear(lotQty)
    array.clear(lotPrice)
    array.clear(lotTags)
    array.clear(lotUsdt)
    restartedThisBar := false
    [barEvents, barHasAction] = f_addEvent(barEvents, "LIVE SYNC RESET")

// =====================
// RESET + immediate restart
// =====================
if liveNow and resetCycle
    posSizeAbs       := 0.0
    posProceedsUSDT  := 0.0
    avgPrice         := na
    numSells         := 0
    lastFillPrice    := na
    nextLevelPrice   := na
    trailingActive   := false
    trailingMin      := na
    cycleBaseQtyCoin := na
    cycleScCounter   := 0
    array.clear(lotIds)
    array.clear(lotQty)
    array.clear(lotPrice)
    array.clear(lotTags)
    array.clear(lotUsdt)
    resetCycle := false

    if f_canPlaceOrder()
        cycleBaseQtyCoin := f_calcBaseOrderQtyCoin()
        sellQty  = cycleBaseQtyCoin
        sellUSDT = sellQty * close
        lotCounter += 1
        id0  = "S" + str.tostring(lotCounter)
        tag0 = f_lotTag(1)

        ordersThisBar += 1
        if ordersThisBar > maxOrdersPerBarBT
            maxOrdersPerBarBT := ordersThisBar
            maxOrdersBarTime  := time

        qty0  = sellQty
        fill0 = close

        array.push(lotIds,  id0)
        array.push(lotQty,  qty0)
        array.push(lotPrice, fill0)
        array.push(lotTags,  tag0)
        array.push(lotUsdt,  sellUSDT)

        posSizeAbs      += qty0
        posProceedsUSDT += sellUSDT
        avgPrice        := fill0
        numSells        := 1
        lastFillPrice   := fill0
        nextLevelPrice  := f_nextLevel(lastFillPrice, numSells)

        f_execEntry(id0, sellQty, "Restart Short_0", "RESTART_SHORT", tag0, fill0, fill0, avgPrice, avgPrice * (1.0 - tpPercent / 100.0), nextLevelPrice, numSells)

        info = tag0 + " @" + str.tostring(fill0, "#.####") + " (" + str.tostring(sellQty, "#.###") + "q)"
        restartedThisBar := true
        [barEvents, barHasAction] = f_addEvent(barEvents, "RESTART " + info)

// =====================
// Start new cycle if flat
// =====================
if liveNow and posSizeAbs == 0 and array.size(lotIds) == 0 and not resetCycle and not restartedThisBar
    if f_canPlaceOrder()
        cycleBaseQtyCoin := f_calcBaseOrderQtyCoin()
        sellQty  = cycleBaseQtyCoin
        sellUSDT = sellQty * close
        lotCounter += 1
        id0  = "S" + str.tostring(lotCounter)
        tag0 = f_lotTag(1)

        ordersThisBar += 1
        if ordersThisBar > maxOrdersPerBarBT
            maxOrdersPerBarBT := ordersThisBar
            maxOrdersBarTime  := time

        qty0  = sellQty
        fill0 = close

        array.push(lotIds,  id0)
        array.push(lotQty,  qty0)
        array.push(lotPrice, fill0)
        array.push(lotTags,  tag0)
        array.push(lotUsdt,  sellUSDT)

        posSizeAbs      += qty0
        posProceedsUSDT += sellUSDT
        avgPrice        := fill0
        numSells        := 1
        lastFillPrice   := fill0
        nextLevelPrice  := f_nextLevel(lastFillPrice, numSells)

        f_execEntry(id0, sellQty, "First Short_0", "FIRST_SHORT", tag0, fill0, fill0, avgPrice, avgPrice * (1.0 - tpPercent / 100.0), nextLevelPrice, numSells)

        info = tag0 + " @" + str.tostring(fill0, "#.####") + " (" + str.tostring(sellQty, "#.###") + "q)"
        [barEvents, barHasAction] = f_addEvent(barEvents, "FIRST " + info)

// =====================
// TP state
// =====================
tpPrice          = avgPrice * (1.0 - tpPercent / 100.0)
tpTouch          = liveNow and not na(avgPrice) and triggerLow <= tpPrice
fullTPCloseOk    = not requireCloseBelowFullTP or close <= tpPrice
tpCloseConfirmed = tpTouch and fullTPCloseOk

tpBlocksDca = blockDcaOnTpTouch ? tpTouch : tpCloseConfirmed

// =====================
// FULL TP (priority)
// =====================
if liveNow and tpTouch
    if callbackPercent > 0
        trailingActive := true
        trailingMin := na(trailingMin) ? triggerLow : math.min(trailingMin, triggerLow)
        trailStop = trailingMin * (1.0 + callbackPercent / 100.0)

        if tpCloseConfirmed and close >= trailStop and f_canPlaceOrder()
            f_execFullClose("TP Full (Trailing)", "TRAILING_FULL_TP", avgPrice, tpPrice, close, trailingMin, trailStop, posSizeAbs, numSells, tpTouch, tpCloseConfirmed)
            ordersThisBar += 1
            fullTPWarehouseCloses += 1
            if ordersThisBar > maxOrdersPerBarBT
                maxOrdersPerBarBT := ordersThisBar
                maxOrdersBarTime  := time
            resetCycle := true
            [barEvents, barHasAction] = f_addEvent(barEvents, "FULL COVER (trail) @" + str.tostring(close, "#.####"))
    else
        if tpCloseConfirmed and f_canPlaceOrder()
            f_execFullClose("TP Full", "FULL_TP", avgPrice, tpPrice, close, na, na, posSizeAbs, numSells, tpTouch, tpCloseConfirmed)
            ordersThisBar += 1
            fullTPWarehouseCloses += 1
            if ordersThisBar > maxOrdersPerBarBT
                maxOrdersPerBarBT := ordersThisBar
                maxOrdersBarTime  := time
            resetCycle := true
            [barEvents, barHasAction] = f_addEvent(barEvents, "FULL COVER @" + str.tostring(close, "#.####"))

// =====================
// DCA shorts
// =====================
if liveNow and not tpBlocksDca and posSizeAbs > 0 and not restartedThisBar
    canSellMore = numSells < marginCallLimit
    fills = 0

    while canSellMore and fills < maxFillsPerBar and not na(nextLevelPrice) and triggerHigh >= nextLevelPrice and (not requireCloseAboveDcaLevel or close >= nextLevelPrice) and f_canPlaceOrder()
        mult    = f_getMultForNextLevel(numSells)
        if na(cycleBaseQtyCoin)
            cycleBaseQtyCoin := f_calcBaseOrderQtyCoin()
        sellQty  = cycleBaseQtyCoin * mult
        sellUSDT = sellQty * close

        lotCounter += 1
        id   = "S" + str.tostring(lotCounter)
        newLevel = numSells + 1
        tag      = f_lotTag(newLevel)
        triggerLevel = nextLevelPrice

        ordersThisBar += 1
        if ordersThisBar > maxOrdersPerBarBT
            maxOrdersPerBarBT := ordersThisBar
            maxOrdersBarTime  := time

        fillP = close
        qtyS  = sellQty

        array.push(lotIds,   id)
        array.push(lotQty,   qtyS)
        array.push(lotPrice, fillP)
        array.push(lotTags,  tag)
        array.push(lotUsdt,  sellUSDT)

        posSizeAbs      += qtyS
        posProceedsUSDT += sellUSDT
        avgPrice        := f_recalcAvg(posProceedsUSDT, posSizeAbs)

        numSells       += 1
        lastFillPrice  := triggerLevel
        nextLevelPrice := f_nextLevel(lastFillPrice, numSells)

        f_execEntry(id, sellQty, "DCA Short", "DCA_SHORT", tag, triggerLevel, fillP, avgPrice, avgPrice * (1.0 - tpPercent / 100.0), nextLevelPrice, numSells)

        trailingActive := false
        trailingMin    := na

        dcaLine = tag + " close@" + str.tostring(fillP, "#.####") +
             " trg@" + str.tostring(triggerLevel, "#.####") +
             " (" + str.tostring(sellQty, "#.###") + "q)" +
             "  sc-TP<=" + str.tostring(fillP * (1.0 - subSellTPPercent / 100.0), "#.####")

        barDcaBlock := barDcaBlock == "" ? dcaLine : barDcaBlock + "\n" + dcaLine

        fills       += 1
        canSellMore := numSells < marginCallLimit

    if barDcaBlock != ""
        [barEvents, barHasAction] = f_addEvent(barEvents, barDcaBlock)

// =====================
// SUB-COVER
// =====================
if liveNow and not tpBlocksDca and posSizeAbs > 0 and numSells > 5 and not restartedThisBar
    covered    = 0
    anyCovered = false

    while covered < maxSubSellsPerBar and f_canPlaceOrder()
        lastIdx = array.size(lotIds) - 1
        if lastIdx < 0
            break

        idLast    = array.get(lotIds,   lastIdx)
        qtyLast   = array.get(lotQty,   lastIdx)
        entryLast = array.get(lotPrice, lastIdx)
        tagLast   = array.get(lotTags,  lastIdx)
        usdtLast  = array.get(lotUsdt,  lastIdx)

        lastLotTP = entryLast * (1.0 - subSellTPPercent / 100.0)
        subCoverTouch = triggerLow <= lastLotTP

        subCoverCloseOk =
             subCoverCloseConfirmMode == "off" ? true :
             subCoverCloseConfirmMode == "breakeven" ? (close <= entryLast) :
             (close <= lastLotTP)

        if subCoverTouch and subCoverCloseOk
            anyCovered      := true
            cycleScCounter  += 1
            f_execSubCover(idLast, "Sub-cover last lot", tagLast, qtyLast, entryLast, lastLotTP, close, avgPrice, posSizeAbs, numSells)
            ordersThisBar += 1
            if ordersThisBar > maxOrdersPerBarBT
                maxOrdersPerBarBT := ordersThisBar
                maxOrdersBarTime  := time

            entryProceedsUSDT = qtyLast * entryLast
            profitUSDT        = qtyLast * (entryLast - close)

            posSizeAbs      -= qtyLast
            posProceedsUSDT -= entryProceedsUSDT

            if autoMerge
                posProceedsUSDT -= profitUSDT // Keep the original merge math to preserve parity with the base short version.

            avgPrice := f_recalcAvg(posProceedsUSDT, posSizeAbs)

            array.pop(lotIds)
            array.pop(lotQty)
            array.pop(lotPrice)
            array.pop(lotTags)
            array.pop(lotUsdt)

            numSells := math.max(numSells - 1, 0)
            covered  += 1

            scLine =
                 "sc" + str.tostring(cycleScCounter) +
                 " <- " + tagLast +
                 " @" + str.tostring(entryLast, "#.####") +
                 " (" + str.tostring(qtyLast, "#.###") + "q)" +
                 "  TP<=" + str.tostring(lastLotTP, "#.####") +
                 "  fill @" + str.tostring(close, "#.####")

            barScBlock := barScBlock == "" ? scLine : barScBlock + "\n" + scLine

            if array.size(lotIds) == 0 or posSizeAbs <= 0
                resetCycle := true
                break
        else
            break

    if barScBlock != ""
        [barEvents, barHasAction] = f_addEvent(barEvents, barScBlock)

    if anyCovered and not resetCycle and array.size(lotPrice) > 0
        lastFillPrice  := array.get(lotPrice, array.size(lotPrice) - 1)
        nextLevelPrice := f_nextLevel(lastFillPrice, numSells)

// FULL COVER - separate yellow label
if barstate.isconfirmed and barHasAction and str.contains(barEvents, "FULL COVER")
    label.new(
         bar_index, close,
         "FULL COVER\n" + barEvents,
         style     = label.style_label_up,
         color     = color.yellow,
         textcolor = color.black,
         size      = size.small)

// Debug
if barstate.isconfirmed and ordersThisBar > 1
    debugText =
         "fills/bar=" + str.tostring(ordersThisBar) +
         "\nrecent3m=" + str.tostring(recentOrdersIn3Min) +
         "\nhistory3m=" + str.tostring(recentHistoryFills) +
         "\ntrgH/L=" + str.tostring(triggerHigh, "#.####") + " / " + str.tostring(triggerLow, "#.####") +
         "\nclose=" + str.tostring(close, "#.####") +
         "\ntpTouch=" + str.tostring(tpTouch) +
         "\ntpCloseConfirmed=" + str.tostring(tpCloseConfirmed) +
         "\ntpBlocksDca=" + str.tostring(tpBlocksDca) +
         "\nsubMode=" + subCoverCloseConfirmMode
    label.new(
         bar_index, high,
         debugText,
         style     = label.style_label_down,
         color     = color.new(color.orange, 0),
         textcolor = color.black,
         size      = size.small)

// Summary label
if barstate.islast
    if not na(maxOrdersLabel)
        label.delete(maxOrdersLabel)
    maxOrdersText =
         "Max fills/bar: " + str.tostring(maxOrdersPerBarBT) +
         "\nbar time: " + (na(maxOrdersBarTime) ? "n/a" : str.format_time(maxOrdersBarTime, "yyyy-MM-dd HH:mm")) +
         "\nMax orders/3m: " + str.tostring(maxOrdersPerWindowBT) +
         "\nwin time: " + (na(maxOrdersWindowTime) ? "n/a" : str.format_time(maxOrdersWindowTime, "yyyy-MM-dd HH:mm")) +
         "\nFull TP closes: " + str.tostring(fullTPWarehouseCloses) +
         "\nTouch mode: " + (useHighLowTouch ? "Low/High" : "Open/Close body") +
         "\nBase size mode: " + (useEquityPctBase ? "fixed equity % per cycle" : "fixed coin qty") +
         "\nSizing equity USDT: " + str.tostring(equityForSizingUSDT, "#.##") +
         "\nclose<=FullTP: " + str.tostring(requireCloseBelowFullTP) +
         "\nsubCover mode: " + subCoverCloseConfirmMode +
         "\nclose>=DCA: " + str.tostring(requireCloseAboveDcaLevel) +
         "\nblockDcaOnTpTouch: " + str.tostring(blockDcaOnTpTouch) +
         "\nexecutionMode: " + executionMode +
         "\nentryAlerts: " + str.tostring(sendEntryAlerts)
    maxOrdersLabel := label.new(
         bar_index, high,
         maxOrdersText,
         style     = label.style_label_left,
         color     = color.new(color.aqua, 0),
         textcolor = color.black,
         size      = size.small)

// =====================
// Plots
// =====================
plot(avgPrice,        "Avg Price",      color=color.new(color.yellow, 0), linewidth=2)
plot(tpPrice,         "TP Price",       color=color.new(color.green,  0), linewidth=2)
plot(nextLevelPrice,  "Next DCA Level", color=color.new(color.red,    0), style=plot.style_cross)
plotchar(numSells,    "Shorts Count", "", location=location.top)
